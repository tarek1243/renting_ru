// Multi-category rental engine schema.
// Migrations are hand-managed under prisma/migrations — the second migration adds
// DB-level guarantees Prisma cannot express (range-exclusion on availability, GIN
// indexes on JSONB attributes). Do not use `prisma migrate dev` to regenerate.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── enums ───────────────────────────

enum UserStatus {
  active
  suspended
  deleted
}

enum LicenseStatus {
  pending
  approved
  rejected
}

enum ListingStatus {
  draft
  active
  inactive
  maintenance
}

enum AttributeDataType {
  text
  number
  boolean
  select
  multiselect
}

enum FilterWidget {
  checkbox
  select
  range
  toggle
}

enum PricingUnit {
  hour
  day
  week
  night
  month
}

enum PriceRuleScope {
  listing
  category
}

enum AdjustmentType {
  percent
  fixed
}

enum AvailabilityReason {
  booking
  maintenance
  manual
}

enum ExtraPriceType {
  per_booking
  per_unit
}

enum BookingStatus {
  pending
  confirmed
  ongoing
  completed
  cancelled
  rejected
}

enum PaymentMethod {
  online
  on_pickup
}

enum PaymentGateway {
  stripe
  regional
  cash
}

enum PaymentType {
  charge
  refund
  deposit_hold
  deposit_release
}

enum PaymentStatus {
  pending
  authorized
  captured
  failed
  refunded
}

enum CouponType {
  percent
  fixed
}

enum ReviewStatus {
  pending
  approved
  rejected
}

enum LocationType {
  branch
  airport
  city_zone
}

enum MediaType {
  image
  video
}

enum NotificationChannel {
  email
  sms
  push
}

enum NotificationStatus {
  queued
  sent
  failed
}

enum WebhookDeliveryStatus {
  pending
  delivered
  failed
  exhausted
}

enum DriverStatus {
  active
  inactive
}

enum SocialProvider {
  google
  apple
  facebook
}

enum PageStatus {
  draft
  published
}

// ─────────────────────── identity & access ───────────────────────

model User {
  id                String     @id @default(uuid()) @db.Uuid
  email             String?    @unique
  phone             String?    @unique
  passwordHash      String?    @map("password_hash")
  firstName         String     @map("first_name")
  lastName          String     @default("") @map("last_name")
  avatarUrl         String?    @map("avatar_url")
  locale            String     @default("en")
  preferredCurrency String     @default("USD") @map("preferred_currency")
  status            UserStatus @default(active)
  emailVerifiedAt   DateTime?  @map("email_verified_at")
  phoneVerifiedAt   DateTime?  @map("phone_verified_at")
  createdAt         DateTime   @default(now()) @map("created_at")
  updatedAt         DateTime   @updatedAt @map("updated_at")

  roles          UserRole[]
  refreshTokens  RefreshToken[]
  socialAccounts SocialAccount[]
  license        DriverLicense?
  driver         Driver?
  bookings       Booking[]
  reviews        Review[]
  favorites      Favorite[]
  notifications  Notification[]
  auditLogs      AuditLog[]      @relation("actor")
  redemptions    CouponRedemption[]

  @@map("users")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique
  permissions RolePermission[]
  users       UserRole[]

  @@map("roles")
}

model Permission {
  id    String           @id @default(uuid()) @db.Uuid
  key   String           @unique
  roles RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String @map("user_id") @db.Uuid
  roleId String @map("role_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  deviceInfo String?   @map("device_info")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model OtpCode {
  id          String   @id @default(uuid()) @db.Uuid
  destination String // phone or email
  codeHash    String   @map("code_hash")
  purpose     String // login | verify_phone | reset_password
  attempts    Int      @default(0)
  expiresAt   DateTime @map("expires_at")
  consumedAt  DateTime? @map("consumed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([destination, purpose])
  @@map("otp_codes")
}

model SocialAccount {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @map("user_id") @db.Uuid
  provider       SocialProvider
  providerUserId String         @map("provider_user_id")
  createdAt      DateTime       @default(now()) @map("created_at")
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@map("social_accounts")
}

model DriverLicense {
  id              String        @id @default(uuid()) @db.Uuid
  userId          String        @unique @map("user_id") @db.Uuid
  numberEncrypted String        @map("number_encrypted") // AES-256-GCM
  country         String
  expiresOn       DateTime      @map("expires_on") @db.Date
  frontImageUrl   String        @map("front_image_url")
  backImageUrl    String?       @map("back_image_url")
  status          LicenseStatus @default(pending)
  reviewedById    String?       @map("reviewed_by_id") @db.Uuid
  reviewedAt      DateTime?     @map("reviewed_at")
  rejectReason    String?       @map("reject_reason")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("driver_licenses")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  before     Json?
  after      Json?
  ip         String?
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")
  actor      User?    @relation("actor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

// ─────────────────────── category engine ───────────────────────

model RentalCategory {
  id          String  @id @default(uuid()) @db.Uuid
  slug        String  @unique
  name        Json // I18nText
  description Json? // I18nText
  icon        String?
  sortOrder   Int     @default(0) @map("sort_order")
  isEnabled   Boolean @default(false) @map("is_enabled")
  config      Json // CategoryConfig
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  attributes   CategoryAttribute[]
  pricingUnits CategoryPricingUnit[]
  listings     Listing[]
  extras       Extra[]
  bookings     Booking[]
  priceRules   PriceRule[]
  coupons      Coupon[]

  @@map("rental_categories")
}

model CategoryAttribute {
  id           String            @id @default(uuid()) @db.Uuid
  categoryId   String            @map("category_id") @db.Uuid
  key          String
  label        Json // I18nText
  dataType     AttributeDataType @map("data_type")
  options      Json? // AttributeOption[]
  unit         String?
  validation   Json? // AttributeValidation
  isRequired   Boolean           @default(false) @map("is_required")
  isFilterable Boolean           @default(false) @map("is_filterable")
  filterWidget FilterWidget?     @map("filter_widget")
  showInCard   Boolean           @default(false) @map("show_in_card")
  sortOrder    Int               @default(0) @map("sort_order")
  category     RentalCategory    @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, key])
  @@map("category_attributes")
}

model CategoryPricingUnit {
  id          String         @id @default(uuid()) @db.Uuid
  categoryId  String         @map("category_id") @db.Uuid
  unit        PricingUnit
  isDefault   Boolean        @default(false) @map("is_default")
  minQuantity Int            @default(1) @map("min_quantity")
  maxQuantity Int            @default(365) @map("max_quantity")
  category    RentalCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, unit])
  @@map("category_pricing_units")
}

// ─────────────────────── listings ───────────────────────

model Listing {
  id           String        @id @default(uuid()) @db.Uuid
  categoryId   String        @map("category_id") @db.Uuid
  slug         String        @unique
  title        Json // I18nText
  description  Json? // I18nText
  status       ListingStatus @default(draft)
  locationId   String?       @map("location_id") @db.Uuid
  lat          Float?
  lng          Float?
  attributes   Json          @default("{}") // validated against CategoryAttribute defs
  avgRating    Decimal       @default(0) @map("avg_rating") @db.Decimal(3, 2)
  reviewsCount Int           @default(0) @map("reviews_count")
  isFeatured   Boolean       @default(false) @map("is_featured")
  viewCount    Int           @default(0) @map("view_count")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  category           RentalCategory      @relation(fields: [categoryId], references: [id])
  location           Location?           @relation(fields: [locationId], references: [id], onDelete: SetNull)
  media              ListingMedia[]
  prices             ListingPrice[]
  priceRules         PriceRule[]
  availabilityBlocks AvailabilityBlock[]
  bookings           Booking[]
  reviews            Review[]
  favorites          Favorite[]

  @@index([categoryId, status])
  @@map("listings")
}

model ListingMedia {
  id        String    @id @default(uuid()) @db.Uuid
  listingId String    @map("listing_id") @db.Uuid
  type      MediaType @default(image)
  url       String
  sortOrder Int       @default(0) @map("sort_order")
  isCover   Boolean   @default(false) @map("is_cover")
  listing   Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@map("listing_media")
}

model ListingPrice {
  id          String      @id @default(uuid()) @db.Uuid
  listingId   String      @map("listing_id") @db.Uuid
  pricingUnit PricingUnit @map("pricing_unit")
  currency    String      @default("USD")
  basePrice   Decimal     @map("base_price") @db.Decimal(12, 2)
  listing     Listing     @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, pricingUnit, currency])
  @@map("listing_prices")
}

model PriceRule {
  id              String          @id @default(uuid()) @db.Uuid
  scope           PriceRuleScope
  listingId       String?         @map("listing_id") @db.Uuid
  categoryId      String?         @map("category_id") @db.Uuid
  name            String
  startsOn        DateTime?       @map("starts_on") @db.Date
  endsOn          DateTime?       @map("ends_on") @db.Date
  daysOfWeek      Int[]           @default([]) @map("days_of_week") // 0=Sun..6=Sat, empty = all
  adjustmentType  AdjustmentType  @map("adjustment_type")
  adjustmentValue Decimal         @map("adjustment_value") @db.Decimal(12, 2)
  priority        Int             @default(0)
  isActive        Boolean         @default(true) @map("is_active")
  createdAt       DateTime        @default(now()) @map("created_at")
  listing         Listing?        @relation(fields: [listingId], references: [id], onDelete: Cascade)
  category        RentalCategory? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([listingId])
  @@index([categoryId])
  @@map("price_rules")
}

model AvailabilityBlock {
  id        String             @id @default(uuid()) @db.Uuid
  listingId String             @map("listing_id") @db.Uuid
  startAt   DateTime           @map("start_at")
  endAt     DateTime           @map("end_at")
  reason    AvailabilityReason
  bookingId String?            @unique @map("booking_id") @db.Uuid
  note      String?
  createdAt DateTime           @default(now()) @map("created_at")
  listing   Listing            @relation(fields: [listingId], references: [id], onDelete: Cascade)
  booking   Booking?           @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  // A generated tstzrange column + EXCLUDE USING gist constraint are added in
  // migration 0002 — overlapping blocks for one listing are impossible at DB level.
  @@index([listingId, startAt, endAt])
  @@map("availability_blocks")
}

model Extra {
  id         String         @id @default(uuid()) @db.Uuid
  categoryId String         @map("category_id") @db.Uuid
  name       Json // I18nText
  price      Decimal        @db.Decimal(12, 2)
  priceType  ExtraPriceType @default(per_booking) @map("price_type")
  isActive   Boolean        @default(true) @map("is_active")
  category   RentalCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  bookings   BookingExtra[]

  @@map("extras")
}

// ─────────────────────── drivers ───────────────────────

model Driver {
  id                String       @id @default(uuid()) @db.Uuid
  userId            String       @unique @map("user_id") @db.Uuid
  bio               Json? // I18nText
  photoUrl          String?      @map("photo_url")
  languages         String[]     @default([])
  yearsExperience   Int          @default(0) @map("years_experience")
  hourlyRate        Decimal      @default(0) @map("hourly_rate") @db.Decimal(12, 2)
  dailyRate         Decimal      @default(0) @map("daily_rate") @db.Decimal(12, 2)
  commissionPercent Decimal      @default(0) @map("commission_percent") @db.Decimal(5, 2)
  avgRating         Decimal      @default(0) @map("avg_rating") @db.Decimal(3, 2)
  ratingsCount      Int          @default(0) @map("ratings_count")
  status            DriverStatus @default(active)
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules DriverSchedule[]
  timeOff   DriverTimeOff[]
  bookings  Booking[]
  reviews   Review[]

  @@map("drivers")
}

model DriverSchedule {
  id        String @id @default(uuid()) @db.Uuid
  driverId  String @map("driver_id") @db.Uuid
  dayOfWeek Int    @map("day_of_week") // 0=Sun..6=Sat
  startTime String @map("start_time") // "08:00"
  endTime   String @map("end_time") // "20:00"
  driver    Driver @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@unique([driverId, dayOfWeek])
  @@map("driver_schedules")
}

model DriverTimeOff {
  id       String   @id @default(uuid()) @db.Uuid
  driverId String   @map("driver_id") @db.Uuid
  startAt  DateTime @map("start_at")
  endAt    DateTime @map("end_at")
  reason   String?
  driver   Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)

  @@index([driverId, startAt, endAt])
  @@map("driver_time_off")
}

// ─────────────────────── bookings & money ───────────────────────

model Booking {
  id                    String        @id @default(uuid()) @db.Uuid
  code                  String        @unique
  categoryId            String        @map("category_id") @db.Uuid
  listingId             String        @map("listing_id") @db.Uuid
  customerId            String        @map("customer_id") @db.Uuid
  status                BookingStatus @default(pending)
  startAt               DateTime      @map("start_at")
  endAt                 DateTime      @map("end_at")
  pricingUnit           PricingUnit   @map("pricing_unit")
  unitQuantity          Int           @map("unit_quantity")
  pickupLocationId      String?       @map("pickup_location_id") @db.Uuid
  dropoffLocationId     String?       @map("dropoff_location_id") @db.Uuid
  withDriver            Boolean       @default(false) @map("with_driver")
  driverId              String?       @map("driver_id") @db.Uuid
  baseAmount            Decimal       @map("base_amount") @db.Decimal(12, 2)
  extrasAmount          Decimal       @default(0) @map("extras_amount") @db.Decimal(12, 2)
  driverAmount          Decimal       @default(0) @map("driver_amount") @db.Decimal(12, 2)
  discountAmount        Decimal       @default(0) @map("discount_amount") @db.Decimal(12, 2)
  taxAmount             Decimal       @default(0) @map("tax_amount") @db.Decimal(12, 2)
  securityDepositAmount Decimal       @default(0) @map("security_deposit_amount") @db.Decimal(12, 2)
  totalAmount           Decimal       @map("total_amount") @db.Decimal(12, 2)
  currency              String        @default("USD")
  couponId              String?       @map("coupon_id") @db.Uuid
  paymentMethod         PaymentMethod @map("payment_method")
  customerNotes         String?       @map("customer_notes")
  cancelReason          String?       @map("cancel_reason")
  cancelledAt           DateTime?     @map("cancelled_at")
  meta                  Json          @default("{}")
  createdAt             DateTime      @default(now()) @map("created_at")
  updatedAt             DateTime      @updatedAt @map("updated_at")

  category        RentalCategory       @relation(fields: [categoryId], references: [id])
  listing         Listing              @relation(fields: [listingId], references: [id])
  customer        User                 @relation(fields: [customerId], references: [id])
  driver          Driver?              @relation(fields: [driverId], references: [id], onDelete: SetNull)
  pickupLocation  Location?            @relation("pickup", fields: [pickupLocationId], references: [id], onDelete: SetNull)
  dropoffLocation Location?            @relation("dropoff", fields: [dropoffLocationId], references: [id], onDelete: SetNull)
  coupon          Coupon?              @relation(fields: [couponId], references: [id], onDelete: SetNull)
  extras          BookingExtra[]
  statusHistory   BookingStatusEvent[]
  payments        Payment[]
  invoice         Invoice?
  review          Review?
  availabilityBlock AvailabilityBlock?
  redemption      CouponRedemption?

  @@index([customerId, status])
  @@index([listingId, startAt])
  @@index([status, startAt])
  @@map("bookings")
}

model BookingExtra {
  id        String  @id @default(uuid()) @db.Uuid
  bookingId String  @map("booking_id") @db.Uuid
  extraId   String  @map("extra_id") @db.Uuid
  quantity  Int     @default(1)
  unitPrice Decimal @map("unit_price") @db.Decimal(12, 2)
  total     Decimal @db.Decimal(12, 2)
  booking   Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  extra     Extra   @relation(fields: [extraId], references: [id])

  @@map("booking_extras")
}

model BookingStatusEvent {
  id         String        @id @default(uuid()) @db.Uuid
  bookingId  String        @map("booking_id") @db.Uuid
  fromStatus BookingStatus? @map("from_status")
  toStatus   BookingStatus @map("to_status")
  actorId    String?       @map("actor_id") @db.Uuid
  note       String?
  createdAt  DateTime      @default(now()) @map("created_at")
  booking    Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@map("booking_status_events")
}

model Payment {
  id         String         @id @default(uuid()) @db.Uuid
  bookingId  String         @map("booking_id") @db.Uuid
  gateway    PaymentGateway
  gatewayRef String?        @map("gateway_ref")
  type       PaymentType    @default(charge)
  amount     Decimal        @db.Decimal(12, 2)
  currency   String
  status     PaymentStatus  @default(pending)
  paidAt     DateTime?      @map("paid_at")
  meta       Json           @default("{}")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")
  booking    Booking        @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId])
  @@index([gatewayRef])
  @@map("payments")
}

model Invoice {
  id        String   @id @default(uuid()) @db.Uuid
  bookingId String   @unique @map("booking_id") @db.Uuid
  number    String   @unique
  totals    Json
  pdfUrl    String?  @map("pdf_url")
  issuedAt  DateTime @default(now()) @map("issued_at")
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model Coupon {
  id           String          @id @default(uuid()) @db.Uuid
  code         String          @unique
  type         CouponType
  value        Decimal         @db.Decimal(12, 2)
  categoryId   String?         @map("category_id") @db.Uuid
  minAmount    Decimal         @default(0) @map("min_amount") @db.Decimal(12, 2)
  maxDiscount  Decimal?        @map("max_discount") @db.Decimal(12, 2)
  usageLimit   Int?            @map("usage_limit")
  perUserLimit Int             @default(1) @map("per_user_limit")
  usedCount    Int             @default(0) @map("used_count")
  validFrom    DateTime        @map("valid_from")
  validTo      DateTime        @map("valid_to")
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at")
  category     RentalCategory? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  bookings     Booking[]
  redemptions  CouponRedemption[]

  @@map("coupons")
}

model CouponRedemption {
  id        String   @id @default(uuid()) @db.Uuid
  couponId  String   @map("coupon_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  bookingId String   @unique @map("booking_id") @db.Uuid
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([couponId, userId])
  @@map("coupon_redemptions")
}

// ─────────────────────── engagement & platform ───────────────────────

model Review {
  id           String       @id @default(uuid()) @db.Uuid
  bookingId    String       @unique @map("booking_id") @db.Uuid
  listingId    String       @map("listing_id") @db.Uuid
  customerId   String       @map("customer_id") @db.Uuid
  driverId     String?      @map("driver_id") @db.Uuid
  rating       Int
  driverRating Int?         @map("driver_rating")
  comment      String?
  status       ReviewStatus @default(pending)
  adminReply   String?      @map("admin_reply")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  booking      Booking      @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  listing      Listing      @relation(fields: [listingId], references: [id], onDelete: Cascade)
  customer     User         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  driver       Driver?      @relation(fields: [driverId], references: [id], onDelete: SetNull)

  @@index([listingId, status])
  @@map("reviews")
}

model Favorite {
  userId    String   @map("user_id") @db.Uuid
  listingId String   @map("listing_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@id([userId, listingId])
  @@map("favorites")
}

model Location {
  id          String       @id @default(uuid()) @db.Uuid
  name        Json // I18nText
  type        LocationType @default(branch)
  address     Json? // I18nText
  lat         Float?
  lng         Float?
  city        String?
  countryCode String?      @map("country_code")
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")

  listings        Listing[]
  pickupBookings  Booking[] @relation("pickup")
  dropoffBookings Booking[] @relation("dropoff")

  @@map("locations")
}

model Notification {
  id          String              @id @default(uuid()) @db.Uuid
  userId      String              @map("user_id") @db.Uuid
  channel     NotificationChannel
  templateKey String              @map("template_key")
  payload     Json                @default("{}")
  status      NotificationStatus  @default(queued)
  readAt      DateTime?           @map("read_at")
  sentAt      DateTime?           @map("sent_at")
  error       String?
  attempts    Int                 @default(0)
  createdAt   DateTime            @default(now()) @map("created_at")
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId, createdAt])
  @@map("notifications")
}

model WebhookEndpoint {
  id         String              @id @default(uuid()) @db.Uuid
  name       String
  url        String
  secret     String
  events     String[]            @default([])
  isActive   Boolean             @default(true) @map("is_active")
  createdAt  DateTime            @default(now()) @map("created_at")
  deliveries WebhookDelivery[]

  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id             String                @id @default(uuid()) @db.Uuid
  endpointId     String                @map("endpoint_id") @db.Uuid
  event          String
  payload        Json
  status         WebhookDeliveryStatus @default(pending)
  responseStatus Int?                  @map("response_status")
  attempts       Int                   @default(0)
  nextRetryAt    DateTime?             @map("next_retry_at")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  endpoint       WebhookEndpoint       @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([status, nextRetryAt])
  @@map("webhook_deliveries")
}

model ApiKey {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  keyPrefix       String    @unique @map("key_prefix")
  keyHash         String    @map("key_hash")
  scopes          String[]  @default([])
  rateLimitPerMin Int       @default(60) @map("rate_limit_per_min")
  lastUsedAt      DateTime? @map("last_used_at")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("api_keys")
}

model Setting {
  key       String   @id
  value     Json
  group     String   @default("general")
  isPublic  Boolean  @default(false) @map("is_public")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model ContentPage {
  id        String     @id @default(uuid()) @db.Uuid
  slug      String     @unique
  title     Json // I18nText
  body      Json // I18nText (markdown/html per locale)
  status    PageStatus @default(draft)
  seo       Json?
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("content_pages")
}

model Faq {
  id        String  @id @default(uuid()) @db.Uuid
  question  Json // I18nText
  answer    Json // I18nText
  group     String?
  sortOrder Int     @default(0) @map("sort_order")

  @@map("faqs")
}

model Counter {
  key   String @id
  value Int    @default(0)

  @@map("counters")
}
