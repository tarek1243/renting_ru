# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://renting:renting@localhost:5432/renting_ru?schema=public

# ── Redis (caching, rate-limit counters) ──────────────────
REDIS_URL=redis://localhost:6379

# ── API ───────────────────────────────────────────────────
API_PORT=4000
API_URL=http://localhost:4000
CORS_ORIGINS=http://localhost:3000,http://localhost:3100

# ── Auth ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=900            # seconds (15 min)
JWT_REFRESH_TTL=2592000       # seconds (30 days)
OTP_TTL=300                   # seconds
ENCRYPTION_KEY=32-char-key-for-aes-256-change!!   # exactly 32 chars — license numbers etc.

# ── Payments ──────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
REGIONAL_GATEWAY_API_KEY=
REGIONAL_GATEWAY_SECRET=

# ── Storage (S3-compatible; MinIO in docker-compose) ──────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=renting-media
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/renting-media

# ── Notifications ─────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Renting.ru <no-reply@renting.ru>
SMS_PROVIDER=log              # log | twilio | smsru
SMS_API_KEY=

# ── Frontends ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_GOOGLE_MAPS_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Social login ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
